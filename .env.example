# PostHog Coolify / Docker Compose – set these in Coolify UI (Environment Variables)
# Required
DOMAIN=your-domain.com
POSTHOG_SECRET=
ENCRYPTION_SALT_KEYS=

# Docker images (use official PostHog images or your Coolify registry)
REGISTRY_URL=ghcr.io/posthog/posthog
POSTHOG_APP_TAG=latest
POSTHOG_NODE_TAG=latest

# TLS (leave empty for production Let's Encrypt; set for staging)
# TLS_BLOCK=acme_ca https://acme-staging-v02.api.letsencrypt.org/directory

# Optional
# OPT_OUT_CAPTURE=false
# DOCKER_REGISTRY_PREFIX=
